# Copy this file to `.env` for Docker Compose and containerized local runs.
# Never commit real values.

APP_ENV=development
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=MPI_Project
POSTGRES_HOST=db
POSTGRES_PORT=5432

APP_NAME=Portfolio Tracker API
# Local placeholder only. Production must override this with a strong secret.
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
DEBUG=false
HOST=0.0.0.0
PORT=8000
PRICE_PROVIDER=alpha_vantage
PRICE_PROVIDER_API_KEY=

# Optional: set this when your deployment platform gives you a full connection string.
DATABASE_URL=

# Frontend build-time API base URL
VITE_API_BASE_URL=http://localhost:8000
